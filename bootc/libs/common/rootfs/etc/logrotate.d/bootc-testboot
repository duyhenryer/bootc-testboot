# Top-level logs under /var/log/bootc-testboot only (e.g. app-setup.log).
# Subdirectory logs (hello/*.log, worker/*.log) are in /etc/logrotate.d/hello and
# /etc/logrotate.d/worker with per-service su — do not duplicate paths here.
# See docs/project/008-services-runtime.md
#
# logrotate.service is triggered daily by logrotate.timer; "daily" below means
# eligible for rotation each run (subject to state). Tune rotate / size for disk.
/var/log/bootc-testboot/*.log
{
    daily
    # weekly
    # ~4 weeks of daily archives (was: weekly + rotate 4 ≈ four weeks)
    rotate 28
    missingok
    notifempty
    copytruncate
    compress
    delaycompress

    # Optional disk caps (see logrotate(8)): uncomment if logs spike before the day rolls.
    # maxsize 50M   # rotate early when file exceeds size, but not before the scheduled day
    # size 100M     # size-only: ignores daily/weekly; use instead of daily if you prefer
}
