# Config (from image template — updated on container image upgrade)
LISTEN_ADDR=:8001
LOG_LEVEL=debug
LOG_FORMAT=text
WORKER_MODE=seed
MOCK_DATA_COUNT=100
SEED_CONTINUOUS=true
SEED_RATE_PER_SEC=5

# Connection defaults (can be overridden by shared env in Tier 2)
# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=testboot_db

# RabbitMQ
RABBITMQ_URI=amqp://guest:guest@localhost:5672/
RABBITMQ_QUEUE=worker_queue

# Valkey
VALKEY_ADDR=localhost:6379
VALKEY_DB=0
