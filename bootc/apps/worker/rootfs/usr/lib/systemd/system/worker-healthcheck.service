[Unit]
Description=Periodic HTTP healthcheck for worker (oneshot)
Documentation=file:/usr/lib/systemd/system/worker.service
After=network-online.target worker.service
Wants=network-online.target

[Service]
Type=oneshot
User=worker
Group=worker
ExecStart=/usr/bin/env LOG_FILE=/var/log/bootc-testboot/worker/healthcheck-periodic.log /usr/libexec/testboot/healthcheck.sh http://127.0.0.1:8001/health 10
