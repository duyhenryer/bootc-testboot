[Unit]
Description=MongoDB credential and TLS setup
Before=mongod.service
ConditionPathExists=!/var/lib/mongodb/.setup-done

[Service]
Type=oneshot
RemainAfterExit=yes
Environment=LOG_FILE=/var/log/mongodb/mongodb-setup.log
ExecStart=/usr/libexec/testboot/mongodb-setup.sh

[Install]
WantedBy=multi-user.target
