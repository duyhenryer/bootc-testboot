# =============================================================================
# Base Image: CentOS Stream 9 bootc
# Layer 1: OS packages + production tuning (shared configs)
# =============================================================================
FROM quay.io/centos-bootc/centos-bootc:stream9

# --- System packages ---
RUN dnf install -y epel-release \
    && dnf install -y \
        htop curl jq lsof tcpdump sysstat vim-minimal \
        cloud-init openssh-server firewalld chrony \
    && dnf clean all \
    && rm -rf /var/cache/{dnf,ldconfig} /var/log/{dnf*,hawkey*,rhsm} /var/lib/dnf

# --- Production tuning (Rootfs Overlay) ---
COPY base/rootfs/ /
RUN chmod 0440 /etc/sudoers.d/wheel-nopasswd

# --- Firewall base rules ---
RUN firewall-offline-cmd --zone=public --add-port=22/tcp

# --- Base user ---
RUN useradd -r -m -d /var/home/appuser -s /bin/bash appuser && \
    usermod -aG wheel appuser

# --- Enable base services ---
# CentOS/RHEL: DNS is managed by NetworkManager's internal DNS plugin,
# not systemd-resolved (which is not shipped in the minimal bootc image).
RUN systemctl enable cloud-init sshd firewalld chronyd NetworkManager

# --- Clean /var and /run artifacts from package install + useradd ---
RUN rm -rf /var/home/appuser/.bash* \
    /var/lib/rhsm/productid.js /var/lib/rhsm/repo_server_val \
    /var/roothome/buildinfo \
    /run/cloud-init /run/rhsm

# --- Validate ---
RUN bootc container lint
LABEL containers.bootc=1
